PORT=3000

# Comma-separated origins allowed to call this API.
# Example: https://algofutrix.com,https://www.algofutrix.com
CORS_ORIGINS=

# Firestore collection name
FIRESTORE_COLLECTION=contact_submissions

# Provide ONE of the options below:
#
# Option A: Raw JSON string of service account object
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
#
# Option B: Base64-encoded service account JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=
#
# Option C: File path via GOOGLE_APPLICATION_CREDENTIALS env var
