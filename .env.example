PORT=3000

# Comma-separated origins allowed to call this API.
# Example: https://algofutrix.com,https://www.algofutrix.com
CORS_ORIGINS=

# Cloudflare Turnstile secret key (server-side)
TURNSTILE_SECRET_KEY=

# EmailJS server-side credentials
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
